#!/bin/bash

prepare_dir () {
  dest=`echo "$2/$1" | sed 's!/\+!/!g' | sed 's!/$!!'`
  if [ ! -d "$dest" ]; then
    if [ -n "$VERBOSE" ]; then
        echo "Entering $dest" 1>&2
    fi
    mkdir -p "$dest"
  fi
}

identify_language () {
    shopt -s nocasematch
    LANGUAGE=""
    if [[ $1 =~ ^cargo\.lock$ ]]; then
        LANGUAGE=ini
    elif [[ $1 =~ ^deno\.lock$ ]]; then
        LANGUAGE=json
    fi
    if [[ -n "$LANGUAGE" ]]; then
	    return
    fi

    LANGUAGE=${1#*.}
    if [[ $LANGUAGE =~ plpg\. ]]; then
        LANGUAGE=pgsql
    elif [[ $LANGUAGE =~ erb\. ]]; then
        LANGUAGE=erb
    else
      LANGUAGE=${1##*.}
      if [[ $LANGUAGE =~ containerfile|dockerfile ]]; then
        LANGUAGE=docker
      elif [[ $LANGUAGE =~ jenkinsfile ]]; then
        LANGUAGE=groovy
      elif [[ $LANGUAGE =~ proto ]]; then
        LANGUAGE=protobuf
      elif [[ $LANGUAGE =~ gemfile ]]; then
        LANGUAGE=ruby
      elif [[ $LANGUAGE =~ cue$ ]]; then
        LANGUAGE=javascript
      elif [[ $LANGUAGE =~ mjml$ ]]; then
        LANGUAGE=html
      elif [[ $LANGUAGE =~ stpl$ ]]; then
        LANGUAGE=erb
      fi
    fi
    shopt -u nocasematch
}

code2md () {
  while IFS= read -r f; do
    dir_name=$(dirname "$f")
    prepare_dir "$dir_name" "$2"
    file_name=$(basename "$f")
    if [[ ${file_name%%.*} =~ ^_*index$ ]]; then
      dest_file=`echo "$2/$dir_name/00-$file_name" | sed 's!/\+!/!g'`
    else
      dest_file=`echo "$2/$f" | sed 's!/\+!/!g'`
    fi
    if [[ -n "$VERBOSE" ]]; then
        echo "Generating $dest_file.md" 1>&2
    fi
    if [[ ${file_name##*.} = 'md' ]]; then
      echo '' > "$dest_file"
      head -1 "$1/$f" | grep '\-\-\-' > /dev/null
      if [ $? -eq 1 ]; then
          # add front matter
          echo -e "---\ntitle: $file_name" > "$dest_file"
          git log -n 1 --pretty=format:'date: %ai%nparams:%n  commit: %h%n  message: "%s"' -- "$ORIGIN/$f" >> "$dest_file"
          echo -e "\n---" >> "$dest_file"
      fi
      cat "$1/$f" >> "$dest_file"
    elif [ -f "$1/$f" ]; then
      identify_language "$file_name"
      echo -e "---\ntitle: $file_name" > "$dest_file.md"
      git log -n 1 --pretty=format:'date: %ai%nparams:%n  commit: %h%n  message: "%s"' -- "$ORIGIN/$f" >> "$dest_file.md"
      echo -e "\n---" >> "$dest_file.md"

      echo '```'"$LANGUAGE" >> "$dest_file.md"
      cat "$1/$f" >> "$dest_file.md"
      echo -e '\n```' >> "$dest_file.md"
    fi
  done < <(cd "$1"; git ls-files | grep -v 'themes/codeviewer' | $EXCLUDE_CMD)

  while IFS= read -r d; do
    # generate section list
    DIR=$(basename "$d")
    ORIGIN_DIR=$(echo "$d" | sed "s!$2/*!!")
    echo -e "---\ntitle: $DIR" > "$d/_index.md"
    git log -n 1 --pretty=format:'date: %ai%nparams:%n  commit: %h%n  message: "%s"' -- "$ORIGIN/$ORIGIN_DIR" >> "$d/_index.md"
    echo -e "\n---" >> "$d/_index.md"
  done < <(find "$2" -type d)
  # override top page
  project=`basename $(git remote -v | head -1 | awk '{print $2}' | sed 's/^.*://')`
  echo -e "---\ntitle: ${project%.git}\n---" > "$2/_index.md"
  if [ -n "$ROOT_DOC" ]; then
      cat "$ROOT_DOC" >> "$2/_index.md"
  fi
}

usage () {
  cat <<- 'EOS' 1>&2
	usage: code2md [<options>] <outpur_dir>

	       -d <sub_dir>   root directory under git repository
	       -m <doc_file>  markdown document for top page. Relative path from repo top dir.
	       -v             verbose
	       -x <suffix>    exclude files with backward match.
	EOS
  exit 1
}

EXCLUDE_CMD=cat
while getopts "vd:m:x:h" OPT
do
    case $OPT in
      v) VERBOSE=1
         ;;
      d) SUB_DIR=$OPTARG
         ;;
      m) ROOT_DOC=$OPTARG
         ;;
      x) EXCLUDE_CMD=" grep -v $OPTARG$"
         ;;
      h) usage
         ;;
    esac
done
shift $((OPTIND - 1))

ORIGIN=$(git rev-parse --show-cdup)
if [ $? -ne 0 ]; then
    echo "Not a git repository. Exit"
    exit 1
fi
if [ -n "$ROOT_DOC" ]; then
    ROOT_DOC=./$ORIGIN/$ROOT_DOC
    if [ ! -f $ROOT_DOC ]; then
        echo "No file exists specified with -m option."
        exit 1
    fi
fi
ORIGIN=${ORIGIN:-./}$SUB_DIR

# requires orign & dest dir
if [ $# -lt 1 ]; then
    usage
fi

code2md $ORIGIN $1
